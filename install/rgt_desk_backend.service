[Unit]
Description=RGT Desk Backend
After=network.target

[Service]
User=mfi
WorkingDirectory=/home/mfi/repos/rgt_desk/rgt_desk_backend
Environment="PATH=/home/mfi/repos/rgt_desk/rgt_desk_backend/.venv/bin"
ExecStart=/home/mfi/repos/rgt_desk/rgt_desk_backend/.venv/bin/uvicorn main:app --host 192.168.19.10 --port 8000
Restart=always

[Install]
WantedBy=multi-user.target
